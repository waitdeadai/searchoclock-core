#!/usr/bin/env bash
# socx-run — universal shell-wrapper for harnesses with NO failure hook.
# Runs your command; on a non-zero exit it prints the searchoclock troubleshooting
# protocol to the terminal (where the agent reads it), then exits with the
# command's REAL exit code. Works in any CLI/shell. Apache-2.0.
#
#   socx-run -- npm run build
#   alias build='socx-run -- npm run build'
#
# Requires `socx` on PATH or next to this script.
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
if command -v socx >/dev/null 2>&1; then SOCX="socx"; else SOCX="$DIR/socx"; fi
exec "$SOCX" run -- "$@"
